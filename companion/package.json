{
  "name": "ner-sportscar-companion",
  "version": "1.0.0",
  "description": "NER Sportscar Companion — uploader automatisk dine LMU omgangstider til leaderboardet",
  "main": "electron/main.cjs",
  "author": "NER Sportscar Division",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/math612h/nersportscardevision.git"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite build && electron .",
    "dist": "vite build && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "fast-xml-parser": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.5"
  },
  "build": {
    "appId": "com.nersportscar.companion",
    "productName": "NER Sportscar Companion",
    "artifactName": "NER-Sportscar-Companion-Setup.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "math612h",
        "repo": "nersportscardevision",
        "channel": "latest"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NER Sportscar Companion",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
